# ───────────────────────────────────────────────────────────────
# BE on BSV — environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ───────────────────────────────────────────────────────────────

# --- Server ---
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:5173

# --- Supabase ---
# Project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=
# Anon key — safe to expose to the browser. Used by the React client.
SUPABASE_ANON_KEY=
# Service-role key — server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret used to verify Supabase access tokens server-side.
SUPABASE_JWT_SECRET=

# --- BSV (`@bsv/simple/server`) ---
# Set to "true" to mint real on-chain tickets on registration.
# When false, the server returns a deterministic stub txid so local dev works
# without keys or funded wallets.
BSV_ENABLED=false
# WIF private key for the server-side wallet. Only required when BSV_ENABLED=true.
BSV_SERVER_PRIVATE_KEY=
# Network for the server wallet. "main" for production, "test" for testnet.
BSV_NETWORK=main
# Wallet-toolbox storage backend. The default is the public Babbage instance.
BSV_STORAGE_URL=https://storage.babbage.systems
# Logical basket name for the ticket tokens minted by this app.
BSV_TICKET_BASKET=be-on-bsv-tickets

# --- Email (Resend) ---
# Optional. If unset, registration confirmations are logged to the server console.
RESEND_API_KEY=
EMAIL_FROM="BE on BSV <events@example.com>"

# --- Client (Vite, must be VITE_-prefixed) ---
# Override only when client and server are deployed separately.
VITE_API_BASE=/api
# Mirrored from Supabase above so the React client can talk to Supabase Auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
