{
  "name": "@be-on-bsv/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bsv:generate-key": "tsx scripts/generate-key.ts"
  },
  "dependencies": {
    "@be-on-bsv/shared": "*",
